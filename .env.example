# URL base de la API Laravel (incluye el sufijo /api). Ej: http://localhost:8000/api
NEXT_PUBLIC_API_URL=

# Opcional. URL de la API vista desde el servidor de Next (proxy de fotos).
# En local no hace falta. En Docker, el contenedor no resuelve "localhost":
# usar p.ej. http://host.docker.internal:8000/api
BACKEND_INTERNAL_URL=
